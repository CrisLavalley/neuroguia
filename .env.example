# =========================================================
# 🧠 NEUROGUÍA - ENVIRONMENT CONFIGURATION
# =========================================================

# ---------------------------------------------------------
# 🌐 APP CONFIG
# ---------------------------------------------------------
ENV=development
DEBUG=true

# =========================================================
# 🗄️ DATABASE CONFIGURATION
# =========================================================

# Opciones: sqlite | postgres
DB_BACKEND=sqlite

# ---------------------------------------------------------
# SQLite (modo local por defecto)
# ---------------------------------------------------------
SQLITE_PATH=neuroguia.db

# ---------------------------------------------------------
# PostgreSQL (opcional)
# ---------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

POSTGRES_HOST=your_host
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_SSLMODE=require

# =========================================================
# ☁️ SUPABASE (opcional)
# =========================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =========================================================
# 🤖 OPENAI / LLM CONFIG
# =========================================================

# Activa o desactiva uso de LLM real
USE_OPENAI_LLM=false

# API Key de OpenAI
OPENAI_API_KEY=your_api_key_here

# Modelo recomendado
OPENAI_MODEL=gpt-4.1-mini

# Timeout opcional
OPENAI_TIMEOUT_SECONDS=20

# =========================================================
# 🧠 NEUROGUÍA SETTINGS
# =========================================================

# Activar memoria contextual
ENABLE_USER_MEMORY=true

# Activar registro de curación
ENABLE_CONVERSATION_CURATION=true

# Nivel de logs (opcional)
LOG_LEVEL=info
