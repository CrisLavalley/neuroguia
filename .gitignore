# =========================================================
# 🧠 NEUROGUÍA - .gitignore
# =========================================================

# ---------------------------------------------------------
# 🔐 Variables de entorno (MUY IMPORTANTE)
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# 🐍 Python
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc.*
*.pkl

# Entornos virtuales
venv/
.env/
.venv/
ENV/
env/

# ---------------------------------------------------------
# 📦 Dependencias / caché
# ---------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------
# 🧪 Testing / coverage
# ---------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# ---------------------------------------------------------
# 📊 Bases de datos locales
# ---------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite-journal
*.sqlite3
*.sqlite3-journal

# ---------------------------------------------------------
# 🧾 Logs
# ---------------------------------------------------------
*.log

# ---------------------------------------------------------
# 🧠 Modelos / embeddings (por si se requiere guardar)
# ---------------------------------------------------------
models/
embeddings/
*.bin
*.pt

# ---------------------------------------------------------
# 📁 Archivos temporales del proyecto
# ---------------------------------------------------------
app_tmp_check*
neuroguia_tmp_*
*.tmp

# ---------------------------------------------------------
# 📤 Outputs generados (validaciones, experimentos)
# ---------------------------------------------------------
validation_outputs/*
!validation_outputs/.gitkeep

# En caso de querer conservar ejemplos, puedes crear:
# validation_outputs/sample_results/

# ---------------------------------------------------------
# 🖥️ Sistema operativo
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# 🧠 IDE / Editor
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------
# 🚀 Streamlit
# ---------------------------------------------------------
.streamlit/secrets.toml

# ---------------------------------------------------------
# 📦 Build / distribución (para hecer deploy)
# ---------------------------------------------------------
build/
dist/
*.egg-info/

# ---------------------------------------------------------
# 🧾 Jupyter (en caso de usar)
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# 🔒 Archivos sensibles de Supabase/Postgres
# ---------------------------------------------------------
*.sql.backup
